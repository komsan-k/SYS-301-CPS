      ]
    ]
  },
  {
    "id": "json_or_number",
    "type": "json",
    "z": "tab_rssi_twin",
    "name": "Try JSON",
    "property": "payload",
    "action": "obj",
    "pretty": false,
    "x": 340,
    "y": 80,
    "wires": [
      [
        "normalize_payload"
      ],
      [
        "normalize_payload"
      ]
    ]
  },
  {
    "id": "normalize_payload",
    "type": "function",
    "z": "tab_rssi_twin",
    "name": "Normalize RSSI Payload",
    "func": "let rssi;\n\nif (typeof msg.payload === 'object' && msg.payload !== null) {\n    if (msg.payload.rssi !== undefined) {\n        rssi = Number(msg.payload.rssi);\n    } else if (msg.payload.value !== undefined) {\n        rssi = Number(msg.payload.value);\n    }\n} else {\n    rssi = Number(msg.payload);\n}\n\nif (!Number.isFinite(rssi)) {\n    return null;\n}\n\nlet quality = 'WEAK';\nlet color = '#ff4d4f';\nif (rssi >= -55) {\n    quality = 'STRONG';\n    color = '#52c41a';\n} else if (rssi >= -70) {\n    quality = 'MEDIUM';\n    color = '#faad14';\n}\n\nlet alert = (rssi < -70) ? 'ALERT: Weak signal' : 'Normal';\n\nlet now = new Date();\nmsg.payload = {\n    rssi: rssi,\n    quality: quality,\n    color: color,\n    alert: alert,\n    timestamp: now.toLocaleTimeString(),\n    ts: now.getTime()\n};\n\nreturn msg;",
    "outputs": 1,
    "noerr": 0,
    "initialize": "context.set('history', []);",
    "finalize": "",
    "libs": [],
    "x": 560,
    "y": 100,
    "wires": [
      [
        "fan_out_live",
        "store_stats"
      ]
    ]
  },
  {
    "id": "fan_out_live",
    "type": "function",
    "z": "tab_rssi_twin",
    "name": "Prepare Dashboard Values",
    "func": "return [\n    { payload: msg.payload.rssi },\n    { payload: msg.payload.quality },\n    { payload: msg.payload.alert },\n    { payload: msg.payload.rssi, topic: 'RSSI (dBm)' },\n    { payload: `Time: ${msg.payload.timestamp} | RSSI: ${msg.payload.rssi} dBm | State: ${msg.payload.quality}` },\n    { payload: { rssi: msg.payload.rssi, quality: msg.payload.quality, alert: msg.payload.alert, timestamp: msg.payload.timestamp } }\n];",
    "outputs": 6,
    "noerr": 0,
    "initialize": "",
    "finalize": "",
    "libs": [],
    "x": 820,
    "y": 100,
    "wires": [
      [
        "ui_gauge_rssi"
      ],
      [
        "ui_text_quality"
      ],
      [
        "ui_text_alert"
      ],
      [
        "ui_chart_rssi"
      ],
      [
        "ui_text_status"
      ],
      [
        "debug_live"
      ]
    ]
  },
  {
    "id": "store_stats",
    "type": "function",
    "z": "tab_rssi_twin",
    "name": "Compute Twin Analytics",
    "func": "let history = context.get('history') || [];\nhistory.push(msg.payload.rssi);\nif (history.length > 60) history.shift();\ncontext.set('history', history);\n\nlet min = Math.min(...history);\nlet max = Math.max(...history);\nlet avg = history.reduce((a,b) => a+b, 0) / history.length;\nlet trend = 'STABLE';\nif (history.length >= 2) {\n    let delta = history[history.length - 1] - history[history.length - 2];\n    if (delta > 1) trend = 'IMPROVING';\n    else if (delta < -1) trend = 'DEGRADING';\n}\n\nreturn [\n    { payload: Number(avg.toFixed(2)) },\n    { payload: min },\n    { payload: max },\n    { payload: trend },\n    { payload: { series: ['RSSI Distribution'], data: [[\n        {x: 'Strong', y: history.filter(v => v >= -55).length},\n        {x: 'Medium', y: history.filter(v => v < -55 && v >= -70).length},\n        {x: 'Weak', y: history.filter(v => v < -70).length}\n    ]], labels: ['Strong', 'Medium', 'Weak'] } }\n];",
    "outputs": 5,
    "noerr": 0,
    "initialize": "context.set('history', []);",
    "finalize": "",
    "libs": [],
    "x": 820,
    "y": 180,
    "wires": [
      [
        "ui_text_avg"
      ],
      [
        "ui_text_min"
      ],
      [
        "ui_text_max"
      ],
      [
        "ui_text_trend"
      ],
      [
        "ui_chart_distribution"
      ]
    ]
  },
