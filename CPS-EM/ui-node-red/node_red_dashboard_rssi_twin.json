    "type": "mqtt in",
    "z": "tab_rssi_twin",
    "name": "ESP32 RSSI Input",
    "topic": "esp32/rssi",
    "qos": "0",
    "datatype": "auto",
    "broker": "mqtt_broker_cfg",
    "nl": false,
    "rap": true,
    "rh": 0,
    "inputs": 0,
    "x": 150,
    "y": 100,
