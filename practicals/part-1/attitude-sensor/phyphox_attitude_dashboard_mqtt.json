  {
    "id": "fn_extract_att_001",
    "type": "function",
    "z": "phy_att_tab_001",
    "name": "Extract stable RPY",
    "func": "try {\n    const data = msg.payload;\n    const buffers = data.buffer || {};\n\n    function latest(name) {\n        const obj = buffers[name];\n        if (!obj || !obj.buffer || obj.buffer.length === 0) return null;\n        return Number(obj.buffer[obj.buffer.length - 1]);\n    }\n\n    const rollDeg = latest(\"roll\");\n    const pitchDeg = latest(\"pitch\");\n    const yawDeg = latest(\"yaw\");\n\n    if (rollDeg === null || pitchDeg === null || yawDeg === null) {\n        node.warn(\"roll/pitch/yaw buffers not found. Check phyphox experiment and buffer names.\");\n        return null;\n    }\n\n    const roll = rollDeg * Math.PI / 180.0;\n    const pitch = pitchDeg * Math.PI / 180.0;\n    const yaw = yawDeg * Math.PI / 180.0;\n\n    const axis_x = Math.cos(yaw) * Math.cos(pitch);\n    const axis_y = Math.sin(pitch);\n    const axis_z = Math.sin(yaw) * Math.cos(pitch);\n\n    const up_x = Math.cos(yaw) * Math.sin(pitch) * Math.sin(roll) - Math.sin(yaw) * Math.cos(roll);\n    const up_y = Math.cos(pitch) * Math.sin(roll);\n    const up_z = Math.sin(yaw) * Math.sin(pitch) * Math.sin(roll) + Math.cos(yaw) * Math.cos(roll);\n\n    const full = {\n        ts: Date.now(),\n        rollDeg,\n        pitchDeg,\n        yawDeg,\n        roll,\n        pitch,\n        yaw,\n        axis_x,\n        axis_y,\n        axis_z,\n        up_x,\n        up_y,\n        up_z\n    };\n\n    return [\n        {payload: rollDeg},\n        {payload: pitchDeg},\n        {payload: yawDeg},\n        {payload: full},\n        {topic: \"cps/lab/attitude/rpy\", payload: full}\n    ];\n\n} catch (err) {\n    node.warn(\"Attitude RPY error: \" + err.message);\n    return null;\n}\n",
    "outputs": 5,
    "noerr": 0,
    "x": 860,
    "y": 100,
    "wires": [
      [
        "g_roll_001",
        "chart_roll_001"
      ],
      [
        "g_pitch_001",
        "chart_pitch_001"
      ],
      [
        "g_yaw_001",
        "chart_yaw_001"
      ],
      [
        "ui_json_001",
        "debug_rpy_001"
      ],
      [
        "mqtt_out_att_001"
      ]
    ]
  },
