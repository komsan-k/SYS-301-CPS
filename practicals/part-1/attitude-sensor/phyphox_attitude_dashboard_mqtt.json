  {
    "id": "http_att_001",
    "type": "http request",
    "z": "phy_att_tab_001",
    "name": "GET phyphox Attitude",
    "method": "GET",
    "ret": "obj",
    "paytoqs": "ignore",
    "url": "",
    "tls": "",
    "persist": false,
    "proxy": "",
    "insecureHTTPParser": false,
    "authType": "",
