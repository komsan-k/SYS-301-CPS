    {
        "id": "b4d4d41bfa3a0334",
        "type": "http request",
        "z": "f380f5e726d61588",
        "name": "GET pitch roll yaw",
        "method": "GET",
        "ret": "obj",
        "paytoqs": "ignore",
        "url": "http://172.19.182.135/8080/get?gyrX&gyrY&gyrZ",
        "tls": "",
        "persist": false,
        "proxy": "",
        "insecureHTTPParser": false,
        "authType": "",
        "senderr": false,
        "headers": [],
        "x": 380,
        "y": 100,
        "wires": [
            [
                "276e11645f082a66"
            ]
        ]
    },
    {
        "id": "276e11645f082a66",
        "type": "function",
        "z": "f380f5e726d61588",
        "name": "Extract + radians + axis/up",
        "func": "try {\n    let data = msg.payload;\n\n    let pitchDeg = data.buffer.gyrY.buffer[0];\n    let rollDeg  = data.buffer.gyrX.buffer[0];\n    let yawDeg   = data.buffer.gyrZ.buffer[0];\n\n    let pitch = pitchDeg * Math.PI / 180;\n    let roll  = rollDeg  * Math.PI / 180;\n    let yaw   = yawDeg   * Math.PI / 180;\n\n    let axis_x = Math.cos(yaw) * Math.cos(pitch);\n    let axis_y = Math.sin(pitch);\n    let axis_z = Math.sin(yaw) * Math.cos(pitch);\n\n    let up_x = -Math.sin(roll);\n    let up_y =  Math.cos(roll);\n    let up_z = 0;\n\n    msg.pitchDeg = pitchDeg;\n    msg.rollDeg = rollDeg;\n    msg.yawDeg = yawDeg;\n\n    msg.pitch = pitch;\n    msg.roll = roll;\n    msg.yaw = yaw;\n\n    msg.axis_x = axis_x;\n    msg.axis_y = axis_y;\n    msg.axis_z = axis_z;\n\n    msg.up_x = up_x;\n    msg.up_y = up_y;\n    msg.up_z = up_z;\n\n    msg.payload = {\n        pitchDeg: pitchDeg,\n        rollDeg: rollDeg,\n        yawDeg: yawDeg,\n        pitch: pitch,\n        roll: roll,\n        yaw: yaw,\n        axis_x: axis_x,\n        axis_y: axis_y,\n        axis_z: axis_z,\n        up_x: up_x,\n        up_y: up_y,\n        up_z: up_z\n    };\n\n    return msg;\n} catch(err) {\n    return null;\n}",
        "outputs": 1,
        "timeout": "",
        "noerr": 0,
        "initialize": "",
        "finalize": "",
        "libs": [],
        "x": 650,
        "y": 100,
        "wires": [
            [
