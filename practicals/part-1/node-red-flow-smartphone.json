    {
        "id": "9d1f2e1b41e1fcd3",
        "type": "ui_template",
        "z": "f380f5e726d61588",
        "group": "ui_group_motion",
        "name": "Phone animation",
        "order": 10,
        "width": "12",
        "height": "8",
        "format": "<div style=\"width:100%;height:100%;display:flex;flex-direction:column;align-items:center;justify-content:center;background:#ffffff;\">\n  <div style=\"font-size:20px;font-weight:bold;margin-bottom:14px;color:#333;\">Smartphone Motion Lab</div>\n  <div style=\"perspective:1000px;width:260px;height:380px;display:flex;justify-content:center;align-items:center;\">\n    <div id=\"phone3d\" style=\"width:150px;height:280px;border-radius:24px;background:linear-gradient(180deg,#4e8df5,#2563eb);border:6px solid #173a8f;box-shadow:0 18px 34px rgba(0,0,0,0.25);position:relative;transform-style:preserve-3d;transition:transform 0.1s linear;\">\n      <div style=\"position:absolute;top:10px;left:50%;transform:translateX(-50%);width:50px;height:6px;background:#173a8f;border-radius:6px;\"></div>\n      <div style=\"position:absolute;top:26px;left:50%;transform:translateX(-50%);width:14px;height:14px;background:#173a8f;border-radius:50%;\"></div>\n      <div style=\"position:absolute;bottom:14px;left:50%;transform:translateX(-50%);width:36px;height:36px;border:3px solid rgba(255,255,255,0.85);border-radius:50%;\"></div>\n    </div>\n  </div>\n  <div style=\"margin-top:16px;text-align:center;font-size:14px;line-height:1.6;color:#333;\">\n    <div><b>Pitch:</b> {{msg.payload.pitchDeg.toFixed(2)}}°</div>\n    <div><b>Roll:</b> {{msg.payload.rollDeg.toFixed(2)}}°</div>\n    <div><b>Yaw:</b> {{msg.payload.yawDeg.toFixed(2)}}°</div>\n  </div>\n</div>\n<script>\n(function(scope){\n  scope.$watch('msg', function(msg){\n    if(!msg || !msg.payload) return;\n    var p = msg.payload.pitchDeg || 0;\n    var r = msg.payload.rollDeg || 0;\n    var y = msg.payload.yawDeg || 0;\n    var el = document.getElementById('phone3d');\n    if(el){\n      el.style.transform = 'rotateX(' + (-p) + 'deg) rotateY(' + y + 'deg) rotateZ(' + r + 'deg)';\n    }\n  });\n})(scope);\n</script>",
        "storeOutMessages": true,
