  {
    "id": "ui_template_phone",
    "type": "ui_template",
    "z": "tab_motion_lab",
    "group": "ui_group_motion",
    "name": "Phone visualization",
    "order": 8,
    "width": "12",
    "height": "8",
    "format": "<div style=\"width:100%;height:100%;display:flex;flex-direction:column;align-items:center;justify-content:center;background:#ffffff;\">\n  <div style=\"margin-bottom:12px;font-weight:bold;font-size:18px;color:#333;\">Smartphone Motion Visualization</div>\n  <div style=\"perspective:900px; width:260px; height:420px; display:flex; align-items:center; justify-content:center;\">\n    <div id=\"phoneCard\" style=\"width:140px;height:260px;border-radius:22px;background:linear-gradient(180deg,#4a90e2,#245ec7);border:6px solid #0d2b6b;box-shadow:0 18px 35px rgba(0,0,0,0.25);position:relative;transform-style:preserve-3d;transition:transform 0.12s linear;\">\n      <div style=\"position:absolute;top:10px;left:50%;transform:translateX(-50%);width:50px;height:6px;background:#0d2b6b;border-radius:6px;\"></div>\n      <div style=\"position:absolute;top:28px;left:50%;transform:translateX(-50%);width:16px;height:16px;border-radius:50%;background:#0d2b6b;\"></div>\n      <div style=\"position:absolute;bottom:14px;left:50%;transform:translateX(-50%);width:38px;height:38px;border-radius:50%;border:3px solid rgba(255,255,255,0.8);\"></div>\n    </div>\n  </div>\n  <div style=\"margin-top:16px;font-size:14px;color:#444;text-align:center;line-height:1.5;\">\n    <div><b>Pitch:</b> {{msg.payload.pitchDeg.toFixed(2)}}°</div>\n    <div><b>Roll:</b> {{msg.payload.rollDeg.toFixed(2)}}°</div>\n    <div><b>Yaw:</b> {{msg.payload.yawDeg.toFixed(2)}}°</div>\n  </div>\n</div>\n\n<script>\n(function(scope) {\n    scope.$watch('msg', function(msg) {\n        if (!msg || !msg.payload) return;\n        var p = msg.payload.pitchDeg || 0;\n        var r = msg.payload.rollDeg || 0;\n        var y = msg.payload.yawDeg || 0;\n        var el = document.getElementById('phoneCard');\n        if (el) {\n            el.style.transform = 'rotateX(' + (-p) + 'deg) rotateY(' + y + 'deg) rotateZ(' + r + 'deg)';\n        }\n    });\n})(scope);\n</script>",
    "storeOutMessages": true,
    "fwdInMessages": true,
    "resendOnRefresh": true,
    "templateScope": "local",
    "className": "",
    "x": 870,
    "y": 380,
    "wires": [
