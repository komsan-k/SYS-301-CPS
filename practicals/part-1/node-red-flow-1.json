[
  {
    "id": "tab_motion_lab",
    "type": "tab",
    "label": "Smartphone Motion Lab",
    "disabled": false,
    "info": "Poll smartphone motion data and visualize on dashboard"
  },
  {
    "id": "ui_tab_motion",
    "type": "ui_tab",
    "name": "Motion Lab",
    "icon": "dashboard",
    "disabled": false,
    "hidden": false
  },
  {
    "id": "ui_group_motion",
    "type": "ui_group",
    "name": "Smartphone Orientation",
    "tab": "ui_tab_motion",
    "order": 1,
    "disp": true,
    "width": "12",
    "collapse": false
  },
  {
    "id": "inject_poll",
    "type": "inject",
    "z": "tab_motion_lab",
    "name": "Poll every 0.2 s",
    "props": [
      {
        "p": "payload"
      }
    ],
    "repeat": "0.2",
    "crontab": "",
    "once": true,
    "onceDelay": "1",
    "topic": "",
    "payload": "",
    "payloadType": "date",
    "x": 150,
    "y": 100,
    "wires": [
      [
        "http_request_motion"
      ]
    ]
  },
  {
    "id": "http_request_motion",
    "type": "http request",
    "z": "tab_motion_lab",
    "name": "GET phone motion",
    "method": "GET",
    "ret": "obj",
    "paytoqs": "ignore",
    "url": "http://192.168.1.8:8080/get?pitch&roll&yaw",
    "tls": "",
    "persist": false,
    "proxy": "",
    "insecureHTTPParser": false,
    "authType": "",
    "senderr": false,
    "headers": [],
    "x": 390,
    "y": 100,
    "wires": [
      [
        "fn_extract_motion"
      ]
    ]
  },
  {
    "id": "fn_extract_motion",
    "type": "function",
    "z": "tab_motion_lab",
    "name": "Extract + convert",
    "func": "try {\n    let pitchDeg = msg.payload.buffer.pitch.buffer[0];\n    let rollDeg  = msg.payload.buffer.roll.buffer[0];\n    let yawDeg   = msg.payload.buffer.yaw.buffer[0];\n\n    let pitchRad = pitchDeg * Math.PI / 180;\n    let rollRad  = rollDeg  * Math.PI / 180;\n    let yawRad   = yawDeg   * Math.PI / 180;\n\n    let axis_x = Math.cos(yawRad) * Math.cos(pitchRad);\n    let axis_y = Math.sin(pitchRad);\n    let axis_z = Math.sin(yawRad) * Math.cos(pitchRad);\n\n    let up_x = -Math.sin(rollRad);\n    let up_y =  Math.cos(rollRad);\n    let up_z = 0;\n\n    msg.pitchDeg = pitchDeg;\n    msg.rollDeg = rollDeg;\n    msg.yawDeg = yawDeg;\n\n    msg.pitchRad = pitchRad;\n    msg.rollRad = rollRad;\n    msg.yawRad = yawRad;\n\n    msg.axis = {\n        x: axis_x,\n        y: axis_y,\n        z: axis_z\n    };\n\n    msg.up = {\n        x: up_x,\n        y: up_y,\n        z: up_z\n    };\n\n    msg.payload = {\n        pitchDeg,\n        rollDeg,\n        yawDeg,\n        pitchRad,\n        rollRad,\n        yawRad,\n        axis: msg.axis,\n        up: msg.up\n    };\n\n    return msg;\n} catch (e) {\n    return null;\n}",
    "outputs": 1,
    "noerr": 0,
    "initialize": "",
    "finalize": "",
    "libs": [],
    "x": 630,
    "y": 100,
    "wires": [
      [
        "chg_pitch",
        "chg_roll",
        "chg_yaw",
        "chg_info",
        "ui_template_phone",
        "chg_pitch_rad",
        "chg_roll_rad",
        "chg_yaw_rad"
      ]
    ]
  },
  {
    "id": "chg_pitch",
    "type": "change",
    "z": "tab_motion_lab",
    "name": "Pitch deg",
    "rules": [
      {
        "t": "set",
        "p": "payload",
        "pt": "msg",
        "to": "pitchDeg",
        "tot": "msg"
      }
    ],
    "x": 860,
    "y": 40,
    "wires": [
      [
        "ui_pitch"
      ]
    ]
  },
  {
